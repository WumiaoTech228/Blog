---
// Weather and IP widget Header (standard Astro component)
---
<div class="glass-card visitor-card">
  <div class="visitor-inner">
    <div class="visitor-title">
      <span class="visitor-icon">🌐</span>
      <span>访客雷达</span>
    </div>
    
    <div class="visitor-data-row">
      <div class="visitor-data-item">
        <div class="data-label">您的 IP 地址</div>
        <div id="visitor-ip" class="data-value">获取中...</div>
      </div>
      <div class="visitor-data-item">
        <div class="data-label">地理位置</div>
        <div id="visitor-geo" class="data-value">获取中...</div>
      </div>
    </div>

    <div class="weather-display" id="weather-display">
      <div class="weather-left">
        <div id="weather-temp" class="weather-temp">--°C</div>
        <div id="weather-text" class="weather-text">多云转晴</div>
      </div>
      <div class="weather-right">
        <div id="weather-tips" class="weather-tips">加载实时天气建议...</div>
      </div>
    </div>
  </div>
</div>

<script>
  function initVisitorWidget() {
    const ipEl = document.getElementById('visitor-ip');
    const geoEl = document.getElementById('visitor-geo');
    const tempEl = document.getElementById('weather-temp');
    const textEl = document.getElementById('weather-text');
    const tipsEl = document.getElementById('weather-tips');
    
    if (!ipEl || !geoEl || !tempEl || !textEl || !tipsEl) return;

    let serverDetectedIp = '';

    // 使用 WebRTC 尝试穿透 VPN 代理获取真实的本地/公网出口 IP
    function getRealIPViaWebRTC() {
      try {
        const RTCPeerConnection = window.RTCPeerConnection || (window as any).mozRTCPeerConnection || (window as any).webkitRTCPeerConnection;
        if (!RTCPeerConnection) return;

        // 使用公共 STUN 服务器探测候选连接信息
        const pc = new RTCPeerConnection({
          iceServers: [{ urls: 'stun:stun.l.google.com:19302' }]
        });

        pc.createDataChannel('');
        pc.createOffer().then(offer => pc.setLocalDescription(offer));

        pc.onicecandidate = (ice) => {
          if (!ice || !ice.candidate || !ice.candidate.candidate) return;
          const candidate = ice.candidate.candidate;
          
          // 正则匹配 IPv4 和 IPv6 地址
          const ipRegex = /([0-9]{1,3}(\.[0-9]{1,3}){3})|([a-f0-9]{1,4}(:[a-f0-9]{1,4}){7})/i;
          const match = ipRegex.exec(candidate);
          if (match) {
            const realIp = match[0];
            
            // 排除内网/局域网私有 IP (如 192.168.x.x, 10.x.x.x, 172.16.x.x 至 172.31.x.x)
            const isLocal = realIp.startsWith('192.168.') || 
                            realIp.startsWith('10.') || 
                            realIp.startsWith('127.') ||
                            /^172\.(1[6-9]|2[0-9]|3[0-1])\./.test(realIp) ||
                            realIp.startsWith('fe80:'); // IPv6 本地链路
            
            if (!isLocal && realIp !== serverDetectedIp) {
              // 检测到不同的公网真实 IP（穿透了 VPN），更新界面显示
              ipEl!.innerHTML = `${serverDetectedIp}<br><span style="font-size:0.7rem;color:var(--color-accent);">(穿透真实IP: ${realIp})</span>`;
            }
          }
        };
      } catch (e) {
        console.warn('WebRTC IP leak check blocked or failed:', e);
      }
    }

    async function loadData() {
      try {
        const response = await fetch('/api/weather');
        if (response.ok) {
          const data = await response.json();
          serverDetectedIp = data.ip || 'Unknown';
          ipEl.textContent = serverDetectedIp;
          geoEl.textContent = data.location || '未知位置';
          
          if (data.weather) {
            tempEl.textContent = data.weather.temp;
            textEl.textContent = data.weather.weatherText;
            
            // Set dynamic weather-based greeting suggestions
            const weatherText = data.weather.weatherText;
            let tip = '祝你有美好的一天！✨';
            if (weatherText.includes('晴')) {
              tip = '今天阳光明媚，适合出去散散步走走喔！☀️';
            } else if (weatherText.includes('雨')) {
              tip = '外面正在下雨，出门记得带把伞喔 🌧️';
            } else if (weatherText.includes('云') || weatherText.includes('阴')) {
              tip = '天气有些阴沉/多云，适合坐在窗前静静写代码 ☁️';
            } else if (weatherText.includes('雪')) {
              tip = '外面下雪了！注意保暖，堆个雪人吧 ❄️';
            } else if (weatherText.includes('雷') || weatherText.includes('阵')) {
              tip = '可能有局部强对流天气，注意安全防雷避雨 ⚡';
            } else if (weatherText.includes('雾')) {
              tip = '雾天能见度较低，出行一定要注意安全 🌫️';
            }
            tipsEl.textContent = tip;
          }

          // 核心：在服务器端获取 IP 后，运行 WebRTC 脚本看能否穿透拿到真实的客户端出口公网 IP
          getRealIPViaWebRTC();
        } else {
          fallbackLocally();
        }
      } catch (err) {
        console.error('Failed to fetch visitor radar stats:', err);
        fallbackLocally();
      }
    }

    function fallbackLocally() {
      ipEl.textContent = '127.0.0.1 (本地代理)';
      geoEl.textContent = '环球星辰';
      tempEl.textContent = '22°C';
      textEl.textContent = '晴朗';
      tipsEl.textContent = '无法建立云盾连接。相信直觉，静享写码！☕';
    }

    loadData();
  }

  document.addEventListener('astro:page-load', initVisitorWidget);
</script>

<style>
  .visitor-card {
    padding: 1.5rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .visitor-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  }
  .visitor-inner {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .visitor-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .visitor-data-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
  }
  .visitor-data-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .data-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .data-value {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-main);
    word-break: break-all;
  }
  .weather-display {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
  }
  .weather-left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex-shrink: 0;
  }
  .weather-temp {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1.1;
  }
  .weather-text {
    font-size: 0.82rem;
    color: var(--text-main);
    font-weight: 500;
  }
  .weather-right {
    display: flex;
    align-items: center;
    background: var(--border-color);
    padding: 0.6rem 0.8rem;
    border-radius: var(--radius-sm);
    flex-grow: 1;
  }
  .weather-tips {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
</style>
