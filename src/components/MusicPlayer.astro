---
/**
 * MusicPlayer.astro
 * A floating, premium, lofi music player widget.
 * Persists and plays continuously across page switches using Astro ClientRouter transition:persist.
 */
---
<div id="music-player-persist" class="music-player-widget" transition:persist>
  <!-- Hidden Audio element -->
  <audio id="lofi-audio" preload="auto"></audio>

  <div class="player-inner">
    <!-- Spinning Vinyl Record Container -->
    <div class="vinyl-container" id="lofi-vinyl-btn" role="button" tabindex="0" aria-label="播放/暂停音乐">
      <div class="vinyl-record-wrapper">
        <div class="vinyl-record">
          <svg class="vinyl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <circle cx="12" cy="12" r="10" fill="#18181b" stroke="#333333" stroke-width="0.8" />
            <circle cx="12" cy="12" r="7.5" stroke="#2a2a2a" stroke-width="0.5" stroke-dasharray="1 1" />
            <circle cx="12" cy="12" r="5" stroke="#2a2a2a" stroke-width="0.5" />
            <circle cx="12" cy="12" r="2.5" fill="currentColor" />
            <circle cx="12" cy="12" r="0.8" fill="#ffffff" />
          </svg>
        </div>
        <!-- Static vinyl reflection overlay -->
        <div class="vinyl-reflection"></div>
        <div class="tonearm-container">
          <svg class="tonearm-icon" viewBox="0 0 12 24" fill="none" stroke="currentColor">
            <path d="M6 1 L6 12 L2 18" stroke="var(--color-accent)" stroke-width="1.2" stroke-linecap="round"/>
            <circle cx="6" cy="1" r="1.5" fill="var(--color-accent)"/>
            <rect x="0.5" y="15" width="3" height="4" fill="#a1a1aa" rx="0.5"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Expanded Player Controls and Info -->
    <div class="player-content">
      <div class="player-content-left">
        <div class="track-info">
          <div class="track-name" id="lofi-track-name">加载中...</div>
          <div class="track-status" id="lofi-track-status">已暂停</div>
        </div>
        <div class="progress-container">
          <span id="lofi-current-time" class="time-display">00:00</span>
          <input type="range" id="lofi-progress-slider" min="0" max="100" value="0" class="progress-slider" aria-label="歌曲进度" />
          <span id="lofi-total-time" class="time-display">00:00</span>
        </div>
      </div>

      <div class="player-controls">
        <!-- Previous Track Button -->
        <button id="lofi-prev-btn" class="control-btn" aria-label="上一首" title="上一首">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="19 20 9 12 19 4 19 20" />
            <line x1="5" y1="5" x2="5" y2="19" />
          </svg>
        </button>

        <!-- Play / Pause Button -->
        <button id="lofi-play-btn" class="control-btn" aria-label="播放/暂停">
          <svg class="play-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
          <svg class="pause-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="4" width="4" height="16" />
            <rect x="14" y="4" width="4" height="16" />
          </svg>
        </button>

        <!-- Next Track Button -->
        <button id="lofi-next-btn" class="control-btn" aria-label="下一首" title="下一首">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 4 15 12 5 20 5 4" />
            <line x1="19" y1="5" x2="19" y2="19" />
          </svg>
        </button>

        <!-- Volume Slider Container -->
        <div class="volume-slider-container">
          <!-- Mute / Volume Button -->
          <button id="lofi-mute-btn" class="control-btn" aria-label="静音/取消静音">
            <svg class="volume-up-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
              <path class="volume-waves" d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14" />
            </svg>
            <svg class="volume-mute-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
              <line x1="22" y1="9" x2="16" y2="15" />
              <line x1="16" y1="9" x2="22" y2="15" />
            </svg>
          </button>
          <input type="range" id="lofi-volume-slider" min="0" max="100" value="70" class="volume-slider" aria-label="音量调节" />
        </div>

        <!-- Playlist Button -->
        <button id="lofi-list-btn" class="control-btn" aria-label="播放列表" title="播放列表">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="8" y1="6" x2="21" y2="6" />
            <line x1="8" y1="12" x2="21" y2="12" />
            <line x1="8" y1="18" x2="21" y2="18" />
            <line x1="3" y1="6" x2="3.01" y2="6" />
            <line x1="3" y1="12" x2="3.01" y2="12" />
            <line x1="3" y1="18" x2="3.01" y2="18" />
          </svg>
        </button>
      </div>

      <!-- Playlist Drawer -->
      <div class="playlist-drawer" id="lofi-playlist-drawer">
        <div class="drawer-header">
          <span>播放列表 <span class="track-count-badge" id="lofi-track-count">0</span></span>
          <div class="drawer-search-container">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="lofi-playlist-search" placeholder="搜索歌曲/歌手..." autocomplete="off" />
          </div>
        </div>
        <div class="drawer-list" id="lofi-drawer-list">
          <!-- Songs list injected here -->
        </div>
      </div>

      <!-- Simulated Wave Visualizer -->
      <div class="visualizer" id="lofi-visualizer">
        <span class="bar bar-1"></span>
        <span class="bar bar-2"></span>
        <span class="bar bar-3"></span>
        <span class="bar bar-4"></span>
      </div>
    </div>
  </div>
</div>

<div id="lofi-lyrics-overlay" class="lyrics-overlay" aria-live="polite" transition:persist>
  <div id="lofi-lyrics-line" class="lyrics-line"></div>
  <div id="lofi-lyrics-meta" class="lyrics-meta"></div>
</div>

<script>
  interface Track {
    id?: number;
    name: string;
    artist: string;
    url: string;
  }

  interface LyricLine {
    time: number;
    text: string;
  }

  import DEFAULT_TRACKS from '../data/netease-playlist.json';

  const activeTracks: Track[] = [...DEFAULT_TRACKS];

  let consecutiveErrors = 0;
  let isDraggingProgress = false;
  const lyricsCache = new Map<number, LyricLine[]>();
  let currentLyrics: LyricLine[] = [];
  let currentLyricIndex = -1;
  let lyricsRequestToken = 0;


  function getAudioElements() {
    const audio = document.getElementById('lofi-audio') as HTMLAudioElement | null;
    const container = document.getElementById('music-player-persist') as HTMLElement | null;
    const vinyl = document.getElementById('lofi-vinyl-btn') as HTMLElement | null;
    const playBtn = document.getElementById('lofi-play-btn') as HTMLButtonElement | null;
    const prevBtn = document.getElementById('lofi-prev-btn') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('lofi-next-btn') as HTMLButtonElement | null;
    const muteBtn = document.getElementById('lofi-mute-btn') as HTMLButtonElement | null;
    const trackNameEl = document.getElementById('lofi-track-name') as HTMLElement | null;
    const trackStatusEl = document.getElementById('lofi-track-status') as HTMLElement | null;

    const listBtn = document.getElementById('lofi-list-btn') as HTMLButtonElement | null;
    const drawer = document.getElementById('lofi-playlist-drawer') as HTMLElement | null;
    const drawerList = document.getElementById('lofi-drawer-list') as HTMLElement | null;

    const progressSlider = document.getElementById('lofi-progress-slider') as HTMLInputElement | null;
    const currentTimeEl = document.getElementById('lofi-current-time') as HTMLElement | null;
    const totalTimeEl = document.getElementById('lofi-total-time') as HTMLElement | null;
    const lyricsOverlay = document.getElementById('lofi-lyrics-overlay') as HTMLElement | null;
    const lyricsLineEl = document.getElementById('lofi-lyrics-line') as HTMLElement | null;
    const lyricsMetaEl = document.getElementById('lofi-lyrics-meta') as HTMLElement | null;

    return { audio, container, vinyl, playBtn, prevBtn, nextBtn, muteBtn, trackNameEl, trackStatusEl, listBtn, drawer, drawerList, progressSlider, currentTimeEl, totalTimeEl, lyricsOverlay, lyricsLineEl, lyricsMetaEl };
  }

  function parseLyrics(raw: string): LyricLine[] {
    return raw
      .split(/\r?\n/)
      .flatMap(line => {
        const text = line.replace(/\[[^\]]+\]/g, '').trim();
        if (!text) return [];

        const matches = [...line.matchAll(/\[(\d{1,2}):(\d{2})(?:\.(\d{1,3}))?\]/g)];
        return matches.map(match => {
          const minutes = parseInt(match[1], 10);
          const seconds = parseInt(match[2], 10);
          const fraction = match[3] ? parseInt(match[3].padEnd(3, '0').slice(0, 3), 10) / 1000 : 0;
          return {
            time: minutes * 60 + seconds + fraction,
            text
          };
        });
      })
      .sort((a, b) => a.time - b.time);
  }

  function clearLyrics() {
    currentLyrics = [];
    currentLyricIndex = -1;
    const { lyricsOverlay, lyricsLineEl, lyricsMetaEl } = getAudioElements();
    lyricsOverlay?.classList.remove('is-visible');
    if (lyricsLineEl) lyricsLineEl.textContent = '';
    if (lyricsMetaEl) lyricsMetaEl.textContent = '';
  }

  function updateLyricsMeta(track: Track) {
    const { lyricsMetaEl } = getAudioElements();
    if (lyricsMetaEl) {
       lyricsMetaEl.textContent = `—— ${track.name} / ${track.artist}`;
    }
  }

  function showLyricLine(index: number) {
    if (index === currentLyricIndex || !currentLyrics[index]) return;

    const currentIndex = parseInt(getAudioElements().audio?.dataset.currentIndex || '0', 10);
    const track = activeTracks[currentIndex];
    const { lyricsOverlay, lyricsLineEl } = getAudioElements();
    if (!lyricsOverlay || !lyricsLineEl || !track) return;

    currentLyricIndex = index;
    lyricsLineEl.textContent = currentLyrics[index].text;
    updateLyricsMeta(track);
    lyricsOverlay.classList.add('is-visible');
  }

  function syncLyrics(currentTime: number) {
    if (currentLyrics.length === 0) return;

    let nextIndex = -1;
    for (let i = 0; i < currentLyrics.length; i++) {
      if (currentLyrics[i].time <= currentTime + 0.25) {
        nextIndex = i;
      } else {
        break;
      }
    }

    if (nextIndex >= 0) {
      showLyricLine(nextIndex);
    }
  }

  async function loadLyrics(track: Track) {
    const token = ++lyricsRequestToken;
    clearLyrics();
    if (!track.id) return;

    try {
      if (!lyricsCache.has(track.id)) {
        const response = await fetch(`https://music.163.com/api/song/lyric?id=${track.id}&lv=1&kv=1&tv=-1`);
        if (!response.ok) throw new Error(`Lyrics request failed: ${response.status}`);

        const data = await response.json();
        const lyricText = data?.lrc?.lyric || '';
        lyricsCache.set(track.id, parseLyrics(lyricText));
      }

      if (token !== lyricsRequestToken) return;
      currentLyrics = lyricsCache.get(track.id) || [];
      currentLyricIndex = -1;
      updateLyricsMeta(track);
    } catch (err) {
      console.debug('姝岃瘝鍔犺浇澶辫触:', err);
      if (token === lyricsRequestToken) {
        clearLyrics();
      }
    }
  }

  function renderPlaylist() {
    const { drawerList, audio } = getAudioElements();
    if (!drawerList) return;
    
    const currentIndex = parseInt(audio?.dataset.currentIndex || '0', 10);
    const searchInput = document.getElementById('lofi-playlist-search') as HTMLInputElement | null;
    const countEl = document.getElementById('lofi-track-count') as HTMLElement | null;
    const query = (searchInput?.value || '').trim().toLowerCase();
    
    const itemsHTML: string[] = [];
    let visibleCount = 0;
    
    activeTracks.forEach((track, index) => {
      const matchName = track.name.toLowerCase().includes(query);
      const matchArtist = track.artist.toLowerCase().includes(query);
      if (query && !matchName && !matchArtist) return;
      
      visibleCount++;
      const isActive = index === currentIndex;
      
      itemsHTML.push(`
        <div class="playlist-item ${isActive ? 'active' : ''}" data-index="${index}">
          <div class="item-left">
            <span class="item-index">${isActive ? `
              <span class="playing-equalizer">
                <span class="eq-bar eq-bar-1"></span>
                <span class="eq-bar eq-bar-2"></span>
                <span class="eq-bar eq-bar-3"></span>
              </span>
            ` : (index + 1).toString().padStart(2, '0')}</span>
            <div class="item-meta">
              <span class="item-name" title="${track.name}">${track.name}</span>
              <span class="item-artist" title="${track.artist}">${track.artist}</span>
            </div>
          </div>
          <div class="item-right">
            ${isActive ? '<span class="playing-badge">PLAYING</span>' : ''}
          </div>
        </div>
      `);
    });
    
    if (countEl) {
      countEl.textContent = query ? `${visibleCount}/${activeTracks.length}` : `${activeTracks.length}`;
    }
    
    if (itemsHTML.length === 0) {
      drawerList.innerHTML = `<div class="empty-list-state">没有找到相关歌曲 🎵</div>`;
      return;
    }
    
    drawerList.innerHTML = itemsHTML.join('');
    
    const items = drawerList.querySelectorAll('.playlist-item');
    items.forEach(item => {
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        const index = parseInt(item.getAttribute('data-index') || '0', 10);
        loadTrack(index);
        const { audio: currentAudio } = getAudioElements();
        currentAudio?.play().then(syncUIState).catch(() => {});
      });
    });

    if (!query) {
      const activeItem = drawerList.querySelector('.playlist-item.active') as HTMLElement | null;
      if (activeItem) {
        const parentRect = drawerList.getBoundingClientRect();
        const activeRect = activeItem.getBoundingClientRect();
        if (activeRect.top < parentRect.top) {
          drawerList.scrollTop -= (parentRect.top - activeRect.top);
        } else if (activeRect.bottom > parentRect.bottom) {
          drawerList.scrollTop += (activeRect.bottom - parentRect.bottom);
        }
      }
    }
  }

  function loadTrack(index: number) {
    const { audio, trackNameEl, trackStatusEl, currentTimeEl, totalTimeEl, progressSlider } = getAudioElements();
    if (!audio) return;

    const track = activeTracks[index];
    if (!track) return;

    // Use a direct redirect Meting service to stream the VIP or regular song directly
    if (track.id) {
      audio.src = `https://v.iarc.top/?server=netease&type=url&id=${track.id}`;
    } else {
      audio.src = track.url;
    }

    audio.dataset.currentIndex = index.toString();
    if (trackNameEl) trackNameEl.textContent = track.name;
    if (trackStatusEl) {
      trackStatusEl.textContent = audio.paused ? '已暂停' : track.artist;
    }
    if (currentTimeEl) currentTimeEl.textContent = '00:00';
    if (totalTimeEl) totalTimeEl.textContent = '00:00';
    if (progressSlider) progressSlider.value = '0';
    loadLyrics(track);

    renderPlaylist();
  }

  function syncUIState() {
    const { audio, container, trackStatusEl, trackNameEl } = getAudioElements();
    if (!audio || !container) return;

    // Toggle playing class
    if (audio.paused) {
      container.classList.remove('is-playing');
    } else {
      container.classList.add('is-playing');
    }

    // Toggle muted class
    if (audio.muted) {
      container.classList.add('is-muted');
    } else {
      container.classList.remove('is-muted');
    }

    // Sync track texts
    const currentIndex = parseInt(audio.dataset.currentIndex || '0', 10);
    const track = activeTracks[currentIndex];
    if (track) {
      if (trackNameEl) trackNameEl.textContent = track.name;
      if (trackStatusEl) {
        trackStatusEl.textContent = audio.paused ? '已暂停' : track.artist;
      }
    }
    renderPlaylist();
  }

  function togglePlay() {
    const { audio } = getAudioElements();
    if (!audio) return;

    if (audio.paused) {
      audio.play()
        .then(syncUIState)
        .catch(err => console.debug('浏览器阻止了自动播放，需用户手动交互:', err));
    } else {
      audio.pause();
      syncUIState();
    }
  }

  function playNext() {
    const { audio } = getAudioElements();
    if (!audio) return;

    let currentIndex = parseInt(audio.dataset.currentIndex || '0', 10);
    currentIndex = (currentIndex + 1) % activeTracks.length;
    loadTrack(currentIndex);
    audio.play()
      .then(syncUIState)
      .catch(err => console.debug('播放下一首受阻:', err));
  }

  function playPrev() {
    const { audio } = getAudioElements();
    if (!audio) return;

    let currentIndex = parseInt(audio.dataset.currentIndex || '0', 10);
    currentIndex = (currentIndex - 1 + activeTracks.length) % activeTracks.length;
    loadTrack(currentIndex);
    audio.play()
      .then(syncUIState)
      .catch(err => console.debug('播放上一首受阻:', err));
  }

  function toggleMute() {
    const { audio } = getAudioElements();
    const volumeSlider = document.getElementById('lofi-volume-slider') as HTMLInputElement | null;
    if (!audio) return;

    audio.muted = !audio.muted;
    
    if (!audio.muted && audio.volume === 0) {
      audio.volume = 0.3;
      if (volumeSlider) volumeSlider.value = '30';
      localStorage.setItem('lofi-volume', '30');
    }

    syncUIState();
  }

  function formatTime(secs: number): string {
    if (isNaN(secs) || !isFinite(secs)) return '00:00';
    const m = Math.floor(secs / 60);
    const s = Math.floor(secs % 60);
    return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
  }

  function initPlayer() {
    const { audio, container, vinyl, playBtn, prevBtn, nextBtn, muteBtn, listBtn, progressSlider, currentTimeEl, totalTimeEl } = getAudioElements();
    const volumeSlider = document.getElementById('lofi-volume-slider') as HTMLInputElement | null;
    if (!audio || !container) return;

    // Initialize track if none loaded
    if (!audio.src) {
      loadTrack(0);
    }

    // Set initial volume
    const savedVolume = localStorage.getItem('lofi-volume') || '70';
    audio.volume = parseInt(savedVolume, 10) / 100;
    if (volumeSlider) {
      volumeSlider.value = savedVolume;
    }

    syncUIState();
    renderPlaylist();

    if (container.dataset.initialized) return;
    container.dataset.initialized = 'true';

    // Click handlers
    const handleVinylClick = (e: MouseEvent) => {
      const isCollapsed = container.offsetWidth < 60;
      if (isCollapsed) {
        e.preventDefault();
        e.stopPropagation();
        container.classList.add('is-expanded');
        return;
      }
      togglePlay();
    };

    vinyl?.addEventListener('click', handleVinylClick);
    playBtn?.addEventListener('click', togglePlay);
    prevBtn?.addEventListener('click', playPrev);
    nextBtn?.addEventListener('click', playNext);
    muteBtn?.addEventListener('click', toggleMute);

    // Playlist Toggle
    listBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      container.classList.toggle('show-playlist');
      if (container.classList.contains('show-playlist')) {
        setTimeout(renderPlaylist, 50); // Ensure active item is scrolled into view when opened
      }
    });

    // Search input handler
    const searchInput = document.getElementById('lofi-playlist-search') as HTMLInputElement | null;
    searchInput?.addEventListener('input', () => {
      renderPlaylist();
    });

    // Volume Slider handler
    volumeSlider?.addEventListener('input', () => {
      const volVal = parseInt(volumeSlider.value, 10);
      audio.volume = volVal / 100;
      localStorage.setItem('lofi-volume', volumeSlider.value);
      
      if (volVal === 0) {
        audio.muted = true;
      } else {
        audio.muted = false;
      }
      syncUIState();
    });

    // Progress Slider handler
    progressSlider?.addEventListener('mousedown', () => {
      isDraggingProgress = true;
    });
    progressSlider?.addEventListener('touchstart', () => {
      isDraggingProgress = true;
    });

    progressSlider?.addEventListener('input', () => {
      if (!audio.duration) return;
      isDraggingProgress = true;
      const pct = parseFloat(progressSlider.value) / 100;
      if (currentTimeEl) currentTimeEl.textContent = formatTime(audio.duration * pct);
    });

    const stopDrag = () => {
      if (isDraggingProgress) {
        isDraggingProgress = false;
        if (progressSlider && audio && audio.duration) {
          const pct = parseFloat(progressSlider.value) / 100;
          audio.currentTime = audio.duration * pct;
        }
      }
    };

    progressSlider?.addEventListener('change', stopDrag);
    progressSlider?.addEventListener('mouseup', stopDrag);
    progressSlider?.addEventListener('touchend', stopDrag);

    // Click outside to collapse
    document.addEventListener('click', (e) => {
      if (!container.contains(e.target as Node)) {
        container.classList.remove('is-expanded');
        container.classList.remove('show-playlist');
      }
    });

    // Audio status listeners to update UI dynamically
    audio.addEventListener('play', () => {
      consecutiveErrors = 0;
      const { trackStatusEl } = getAudioElements();
      if (trackStatusEl) {
        trackStatusEl.style.color = '';
      }
      syncUIState();
    });
    audio.addEventListener('pause', syncUIState);
    audio.addEventListener('ended', playNext);
    audio.addEventListener('error', (e) => {
      console.warn('播放失败，自动为您跳过至下一首。', e);
      
      const { trackStatusEl } = getAudioElements();
      if (trackStatusEl) {
        trackStatusEl.textContent = '⚠️ 加载失败，正在跳过...';
        trackStatusEl.style.color = '#ef4444';
      }
      
      consecutiveErrors++;
      if (consecutiveErrors >= activeTracks.length) {
        console.error('所有曲目均加载失败。请检查网络连接或资源可用性。');
        if (trackStatusEl) {
          trackStatusEl.textContent = '⚠️ 播放资源不可用';
        }
        audio.pause();
        syncUIState();
        consecutiveErrors = 0; // reset
        return;
      }
      
      setTimeout(playNext, 1500);
    });

    audio.addEventListener('timeupdate', () => {
      if (!audio.duration || isDraggingProgress) return;
      const current = audio.currentTime;
      const duration = audio.duration;
      if (progressSlider) {
        progressSlider.value = ((current / duration) * 100).toString();
      }
      if (currentTimeEl) currentTimeEl.textContent = formatTime(current);
      syncLyrics(current);
    });

    audio.addEventListener('loadedmetadata', () => {
      if (totalTimeEl) totalTimeEl.textContent = formatTime(audio.duration);
    });
  }

  // Handle initialization on initial load and View Transition page changes
  document.addEventListener('astro:page-load', initPlayer);
