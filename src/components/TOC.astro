---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// 过滤 h2 和 h3 标题
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && (
  <div class="toc-container">
    <h4 class="toc-title">目录</h4>
    <ul class="toc-list">
      {tocHeadings.map(h => (
        <li class={`toc-item depth-${h.depth}`}>
          <a href={`#${h.slug}`} class="toc-link" data-slug={h.slug}>
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

<script>
  let observer: IntersectionObserver | null = null;

  function initTOC() {
    // 页面跳转时，先断开前一次的观察器（防止内存泄漏与脏状态）
    if (observer) {
      observer.disconnect();
    }

    const headings = document.querySelectorAll('.prose h2, .prose h3');
    const tocLinks = document.querySelectorAll('.toc-link');

    if (headings.length === 0 || tocLinks.length === 0) return;

    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60% 0px',
      threshold: 0
    };

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          tocLinks.forEach(link => {
            if (link.getAttribute('data-slug') === id) {
              link.classList.add('active');
            } else {
              link.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);
    observer = obs;

    headings.forEach(heading => {
      obs.observe(heading);
    });
  }

  // 监听 astro:page-load，确保在每次单页切换后重新执行挂载逻辑
  document.addEventListener('astro:page-load', initTOC);
</script>

<style>
  .toc-container {
    padding: 0.5rem;
  }
  .toc-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    margin-bottom: 0.8rem;
    color: var(--text-main);
    font-weight: 500;
  }
  .toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .toc-item {
    font-size: 0.85rem;
  }
  .toc-item.depth-3 {
    padding-left: 0.8rem;
    font-size: 0.8rem;
  }
  .toc-link {
    color: var(--text-muted);
    display: block;
    line-height: 1.4;
    transition: color 0.2s ease, border-left-color 0.2s ease;
  }
  .toc-link:hover {
    color: var(--text-main);
  }
  .toc-link.active {
    color: var(--color-accent);
    font-weight: 600;
    border-left: 2px solid var(--color-accent);
    padding-left: 6px;
    margin-left: -8px;
  }
</style>

