---
import { slugifyTag } from '../utils/tag';

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  readingTime: number;
  tags?: string[];
}

const { title, description, date, slug, readingTime, tags = [] } = Astro.props;
const titleId = `post-${slug.replace(/[^\w-]/g, '-')}-title`;

// 格式化日期的辅助函数
const formatDate = (d: Date) => {
  return d.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---
<article class="post-card" aria-labelledby={titleId}>
  <header class="post-card-header">
    <time datetime={date.toISOString()} class="post-card-date">
      {formatDate(date)}
    </time>
    <span class="meta-sep">&middot;</span>
    <span class="post-card-reading">{readingTime} 分钟阅读</span>
  </header>
  <h3 id={titleId} class="post-card-title">
    <a href={`/blog/${slug}/`}>{title}</a>
  </h3>
  <p class="post-card-desc">{description}</p>
  {tags.length > 0 && (
    <div class="post-card-tags">
      {tags.map(tag => (
        <a href={`/tags/${slugifyTag(tag)}/`} class="post-card-tag" aria-label={`查看 ${tag} 标签下的文章`}>#{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2.2rem;
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }
  .post-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: right;
  }
  .post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 36px hsla(var(--hue), 25%, 24%, 0.08);
    border-color: hsla(var(--hue), 25%, 24%, 0.15);
  }
  .post-card:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }
  [data-theme="dark"] .post-card:hover {
    border-color: hsla(var(--hue), 35%, 65%, 0.25);
    box-shadow: 0 16px 36px hsla(var(--hue), 35%, 65%, 0.12);
  }

  .post-card-header {
    display: flex;
    align-items: center;
  }
  .post-card-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .post-card-title {
    font-family: var(--font-sans);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .post-card-title a {
    color: var(--text-main);
  }
  .post-card-title a:hover {
    color: var(--color-accent);
  }
  .post-card-desc {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .meta-sep {
    margin: 0 0.5rem;
    color: var(--text-muted);
    opacity: 0.5;
  }
  .post-card-reading {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .post-card-tag {
    font-size: 0.72rem;
    color: var(--color-accent);
    background: var(--color-accent-bg);
    padding: 0.15rem 0.55rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
  }
  .post-card-tag:hover {
    background: var(--color-accent);
    color: #FFFFFF !important;
    border-color: var(--color-accent);
  }
</style>
