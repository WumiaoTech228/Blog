---
// Header metadata (standard Astro component)
---
<div class="glass-card hitokoto-card">
  <div class="hitokoto-aura"></div>
  <div class="hitokoto-inner">
    <div class="hitokoto-header">
      <span class="hitokoto-tag">💬 每日一言</span>
      <button id="hitokoto-refresh-btn" class="hitokoto-refresh" title="刷新一言" aria-label="刷新一言">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="refresh-icon">
          <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path>
        </svg>
      </button>
    </div>
    
    <div class="hitokoto-content">
      <p id="hitokoto-text" class="hitokoto-text-main">
        理想主义者如果同时也是个行动派，那他就拥有了改变世界的钥匙。
      </p>
      <p id="hitokoto-from" class="hitokoto-author">
        —— 「无渺」
      </p>
    </div>
  </div>
</div>

<script>
  function initHitokoto() {
    const textEl = document.getElementById('hitokoto-text');
    const fromEl = document.getElementById('hitokoto-from');
    const refreshBtn = document.getElementById('hitokoto-refresh-btn');
    if (!textEl || !fromEl || !refreshBtn) return;

    let isFetching = false;

    // 博主精选语录库（包含真正由“无渺”说的话，以及精选技术、折腾语录）
    const wumiaoQuotes = [
      { text: "理想主义者如果同时也是个行动派，那他就拥有了改变世界的钥匙。", author: "无渺" },
      { text: "相信直觉，享受纯粹的写码快乐。", author: "无渺" },
      { text: "代码是写给人看的，顺便给机器运行一下。", author: "无渺" },
      { text: "折腾是一种生活态度，折腾至死，方得始终。", author: "无渺" },
      { text: "凡是可以用 JavaScript 重写的，最终都会被 JavaScript 重写。", author: "Atwood's Law" },
      { text: "生命就像一个不断编译的程序，有 Bug，但一直在迭代运行。", author: "无渺" },
      { text: "在必应和搜索引擎中搜出自己的名字，大概是每个 Vibe Coder 奇妙的里程碑吧。", author: "无渺" }
    ];

    async function fetchHitokoto() {
      if (isFetching) return;
      isFetching = true;
      refreshBtn!.classList.add('spinning');
      
      // 50% 概率展示博主“无渺”自己的原话/精选折腾语录；50% 概率拉取网络名言
      const showLocal = Math.random() > 0.5;

      if (showLocal) {
        const randomQuote = wumiaoQuotes[Math.floor(Math.random() * wumiaoQuotes.length)];
        setTimeout(() => {
          textEl!.textContent = randomQuote.text;
          fromEl!.textContent = `—— 「${randomQuote.author}」`;
          refreshBtn!.classList.remove('spinning');
          isFetching = false;
        }, 300);
      } else {
        try {
          // 拉取公开的名句
          const response = await fetch('https://v1.hitokoto.cn/?c=a&c=b&c=c&c=d&c=h&c=i');
          if (response.ok) {
            const data = await response.json();
            textEl!.textContent = data.hitokoto;
            fromEl!.textContent = data.from_who ? `—— 「${data.from_who}」 · 《${data.from}》` : `—— 《${data.from}》`;
          } else {
            throw new Error();
          }
        } catch (err) {
          // 接口超时/被CSP阻止时 fallback 到本地精选
          const randomQuote = wumiaoQuotes[Math.floor(Math.random() * wumiaoQuotes.length)];
          textEl!.textContent = randomQuote.text;
          fromEl!.textContent = `—— 「${randomQuote.author}」`;
        } finally {
          setTimeout(() => {
            refreshBtn!.classList.remove('spinning');
            isFetching = false;
          }, 600); // 旋转动画最短保持时间
        }
      }
    }

    // 绑定点击事件与初始化
    refreshBtn.addEventListener('click', fetchHitokoto);
    
    // 初始化调用一次
    fetchHitokoto();
  }

  // 支持 Astro View Transitions 的页面跳转事件绑定
  document.addEventListener('astro:page-load', initHitokoto);
</script>

<style>
  .hitokoto-card {
    position: relative;
    overflow: hidden;
    padding: 1.5rem;
    min-height: 140px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hitokoto-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  }
  .hitokoto-aura {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
    transition: transform 0.8s ease;
  }
  .hitokoto-card:hover .hitokoto-aura {
    transform: scale(1.5);
  }
  .hitokoto-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }
  .hitokoto-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .hitokoto-tag {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-bg);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }
  .hitokoto-refresh {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  .hitokoto-refresh:hover {
    color: var(--text-main);
    background: var(--border-color);
  }
  .refresh-icon {
    width: 15px;
    height: 15px;
  }
  .hitokoto-refresh.spinning .refresh-icon {
    animation: spin 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .hitokoto-content {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .hitokoto-text-main {
    font-family: var(--font-serif);
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--text-main);
    margin: 0;
  }
  .hitokoto-author {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-align: right;
    margin: 0;
    font-style: italic;
  }
</style>
