---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { SITE } from '../config';
---

<Layout title={`友情链接 - ${SITE.title}`} description="浏览友情链接以进行交流，或者在留言板下留下你的足迹。">
  <div class="guestbook-layout container">
    <header class="guestbook-header">
      <ScrollReveal animation="fade-up" delay={0}>
        <h1 class="guestbook-title">友情链接</h1>
      </ScrollReveal>
      <ScrollReveal animation="fade-up" delay={80}>
        <p class="guestbook-subtitle">探索本站的友情链接以相互交流，或者在留言墙留下你的足迹。留言保存在本地浏览器中。</p>
      </ScrollReveal>
    </header>

    <!-- 标签切换器 (友情链接在前，留言墙在后) -->
    <ScrollReveal animation="fade-up" delay={120}>
      <div class="tab-switcher-container">
        <div class="tab-switcher glass-pill">
          <button class="tab-btn active" data-tab="friends" aria-label="显示友情链接">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            友情链接
          </button>
          <button class="tab-btn" data-tab="guestbook" aria-label="显示留言墙">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            留言墙
          </button>
          <div class="tab-slider" id="tab-slider"></div>
        </div>
      </div>
    </ScrollReveal>

    <!-- Tab 1: 友情链接内容 (默认激活并展示) -->
    <div id="tab-content-friends" class="tab-content active" style="display: block;">
      <!-- 友情链接卡片网格 -->
      <section class="friends-section">
        <div id="friends-grid" class="friends-grid">
          <!-- 动态渲染的友情链接卡片 -->
        </div>
      </section>

      <!-- 交换友链说明 -->
      <ScrollReveal animation="fade-up" delay={200}>
        <section class="glass-card apply-section">
          <div class="apply-header">
            <h2 class="apply-title">申请交换友链</h2>
            <p class="apply-desc">欢迎优秀的个人博客或技术站点交换链接。请先在贵站添加本站信息，然后直接将您的站点信息发送至邮箱 <a href="mailto:feedback@110228.xyz" class="mail-link">feedback@110228.xyz</a>，我会在 7 个工作日内处理完毕并添加。</p>
          </div>
          
          <div class="apply-info-container">
            <div class="apply-info-list">
              <div class="apply-info-item">
                <span class="info-label">本站名称</span>
                <span class="info-value">无渺</span>
              </div>
              <div class="apply-info-item">
                <span class="info-label">本站链接</span>
                <span class="info-value select-all">https://blog.110228.xyz</span>
              </div>
              <div class="apply-info-item">
                <span class="info-label">头像链接</span>
                <span class="info-value select-all">https://blog.110228.xyz/images/touxiang.png</span>
              </div>
              <div class="apply-info-item">
                <span class="info-label">站点简介</span>
                <span class="info-value">宇宙的边缘，代码的温床。</span>
              </div>
            </div>

            <div class="apply-copy-box">
              <div class="copy-header">
                <span>友链格式 (JSON)</span>
                <button class="copy-btn" id="copy-info-btn">
                  <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                  </svg>
                  <span class="copy-btn-text">复制格式</span>
                </button>
              </div>
              <pre class="code-block"><code id="friend-json-code">{`{
  "name": "无渺",
  "url": "https://blog.110228.xyz",
  "avatar": "https://blog.110228.xyz/images/touxiang.png",
  "description": "宇宙的边缘，代码的温床。"
}`}</code></pre>
            </div>
          </div>
        </section>
      </ScrollReveal>
    </div>

    <!-- Tab 2: 留言墙内容 (默认隐藏) -->
    <div id="tab-content-guestbook" class="tab-content" style="display: none;">
      <!-- 留言提示区 -->
      <ScrollReveal animation="fade-up" delay={140}>
        <div class="guestbook-notice">
          <svg class="notice-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <span class="notice-text">提示：当前留言墙基于本地浏览器存储 (LocalStorage) 运行，您的留言仅在当前设备浏览器中可见且可编辑，清除浏览器缓存将清空所有留言。</span>
        </div>
      </ScrollReveal>

      <!-- 留言表单区 -->
      <ScrollReveal animation="fade-up" delay={160}>
        <section class="glass-card form-section">
          <form id="guestbook-form" class="guestbook-form">
            <div class="form-rows-container">
              <div class="form-row inputs-row">
                <div class="form-group nickname-group">
                  <label for="gb-nickname">昵称</label>
                  <input 
                    type="text" 
                    id="gb-nickname" 
                    placeholder="你的昵称" 
                    required 
                    maxlength="15" 
                    autocomplete="off"
                  />
                </div>
                <div class="form-group content-group">
                  <label for="gb-content">留言内容</label>
                  <input 
                    type="text" 
                    id="gb-content" 
                    placeholder="说点什么吧..." 
                    required 
                    maxlength="100" 
                    autocomplete="off"
                  />
                </div>
              </div>
              
              <div class="form-row meta-row">
                <!-- 心情 Emoji 选择器 -->
                <div class="form-group emoji-picker-group">
                  <label>留言心情</label>
                  <div class="emoji-picker">
                    <label class="emoji-opt">
                      <input type="radio" name="gb-emoji" value="📝" checked />
                      <span class="emoji-btn" title="留言">
                        <svg class="emoji-picker-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 20h9"></path>
                          <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                        </svg>
                        留言
                      </span>
                    </label>
                    <label class="emoji-opt">
                      <input type="radio" name="gb-emoji" value="💡" />
                      <span class="emoji-btn" title="想法">
                        <svg class="emoji-picker-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 18h6"></path>
                          <path d="M10 22h4"></path>
                          <path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z"></path>
                        </svg>
                        想法
                      </span>
                    </label>
                    <label class="emoji-opt">
                      <input type="radio" name="gb-emoji" value="🎉" />
                      <span class="emoji-btn" title="庆祝">
                        <svg class="emoji-picker-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path>
                        </svg>
                        庆祝
                      </span>
                    </label>
                    <label class="emoji-opt">
                      <input type="radio" name="gb-emoji" value="☕" />
                      <span class="emoji-btn" title="闲聊">
                        <svg class="emoji-picker-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
                          <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
                          <line x1="6" y1="1" x2="6" y2="4"></line>
                          <line x1="10" y1="1" x2="10" y2="4"></line>
                          <line x1="14" y1="1" x2="14" y2="4"></line>
                        </svg>
                        闲聊
                      </span>
                    </label>
                    <label class="emoji-opt">
                      <input type="radio" name="gb-emoji" value="💬" />
                      <span class="emoji-btn" title="吐槽">
                        <svg class="emoji-picker-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                        </svg>
                        吐槽
                      </span>
                    </label>
                  </div>
                </div>

                <!-- 便签颜色选择器 -->
                <div class="form-group color-picker-group">
                  <label>便签底色</label>
                  <div class="color-picker">
                    <label class="color-opt color-1">
                      <input type="radio" name="gb-color" value="1" checked />
                      <span class="color-dot" title="柠檬黄"></span>
                    </label>
                    <label class="color-opt color-2">
                      <input type="radio" name="gb-color" value="2" />
                      <span class="color-dot" title="薄荷绿"></span>
                    </label>
                    <label class="color-opt color-3">
                      <input type="radio" name="gb-color" value="3" />
                      <span class="color-dot" title="天空蓝"></span>
                    </label>
                    <label class="color-opt color-4">
                      <input type="radio" name="gb-color" value="4" />
                      <span class="color-dot" title="兰花紫"></span>
                    </label>
                    <label class="color-opt color-5">
                      <input type="radio" name="gb-color" value="5" />
                      <span class="color-dot" title="活力红"></span>
                    </label>
                  </div>
                </div>

                <div class="form-action">
                  <button type="submit" class="btn-primary form-submit-btn">
                    贴上便签
                  </button>
                </div>
              </div>
            </div>
          </form>
        </section>
      </ScrollReveal>

      <!-- 便签展示墙 -->
      <section class="board-section">
        <div id="guestbook-board" class="guestbook-board">
          <!-- 动态渲染的便签卡片 -->
        </div>
      </section>
    </div>
  </div>
</Layout>

<script>
  interface Message {
    id: string;
    nickname: string;
    content: string;
    date: string;
    colorIndex: number;
    emoji?: string;
  }

  interface Friend {
    name: string;
    url: string;
    avatar: string;
    description: string;
    themeColor: string; // HSL Hue or full CSS color rule
  }

  const PRESETS: Omit<Message, 'id'>[] = [
    { nickname: "小飞侠", content: "博客设计的非常有科技感，这个背景漂移光晕太好看了！", date: "2026-06-11", colorIndex: 1, emoji: "💡" },
    { nickname: "折腾党", content: "本站这套 Astro + Cloudflare 部署方案非常棒，免维护体验极佳！", date: "2026-06-11", colorIndex: 2, emoji: "📝" },
    { nickname: "VibeCoder", content: "Cmd+K 这个命令控制面板可以直接切色相，太酷炫了！", date: "2026-06-11", colorIndex: 3, emoji: "🎉" },
    { nickname: "听歌写代码", content: "路过留个爪，顺便听一下左下角的 Lofi 音乐，氛围感拉满。", date: "2026-06-11", colorIndex: 4, emoji: "☕" },
    { nickname: "排版控", content: "中西文字体搭配极具质感，Outfit 与思源宋体简直绝配！", date: "2026-06-11", colorIndex: 5, emoji: "📝" },
    { nickname: "催更人", content: "博主加油，LepoProxy 的并发分流代理什么时候上线？期待开源！", date: "2026-06-11", colorIndex: 1, emoji: "💬" }
  ];

  const FRIENDS: Friend[] = [
    {
      name: "无渺 Space",
      url: "https://blog.110228.xyz",
      avatar: "/images/touxiang.png",
      description: "宇宙的边缘，代码的温床。本站主站。",
      themeColor: "var(--hue)"
    },
    {
      name: "apanzinc",
      url: "https://apanzinc.top/",
      avatar: "https://github.com/apanzinc.png",
      description: "热爱探索的前端开发者，正在不断学习与成长。",
      themeColor: "190"
    },
    {
      name: "OSBox",
      url: "https://osbox.top/",
      avatar: "https://assets.osbox.top/images/favicon.png",
      description: "精简系统镜像、装机 PE 工具与实用软件分享平台。",
      themeColor: "215"
    }
  ];

  function getSavedMessages(): Message[] {
    const data = localStorage.getItem('guestbook_messages');
    if (!data) {
      const initial = PRESETS.map((p, index) => ({
        ...p,
        id: 'preset-' + index
      }));
      localStorage.setItem('guestbook_messages', JSON.stringify(initial));
      return initial;
    }
    try {
      return JSON.parse(data);
    } catch {
      return [];
    }
  }

  function saveMessages(messages: Message[]) {
    localStorage.setItem('guestbook_messages', JSON.stringify(messages));
  }

  function escapeHTML(str: string): string {
    return str.replace(/[&<>"']/g, (m) => {
      switch (m) {
        case '&': return '&amp;';
        case '<': return '&lt;';
        case '>': return '&gt;';
        case '"': return '&quot;';
        case "'": return '&#39;';
        default: return m;
      }
    });
  }

  function createCardHTML(msg: Message): string {
    const colors = ['yellow', 'green', 'blue', 'purple', 'red'];
    const colorClass = `note-color-${colors[msg.colorIndex - 1] || 'yellow'}`;
    
    // Map emoji strings to SVG strings for safe Linux rendering and uniform style
    const EMOJI_MAP: Record<string, string> = {
      '📝': `<svg class="note-emoji-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>`,
      '💡': `<svg class="note-emoji-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"></path><path d="M10 22h4"></path><path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z"></path></svg>`,
      '🎉': `<svg class="note-emoji-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path></svg>`,
      '☕': `<svg class="note-emoji-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path><line x1="6" y1="1" x2="6" y2="4"></line><line x1="10" y1="1" x2="10" y2="4"></line><line x1="14" y1="1" x2="14" y2="4"></line></svg>`,
      '💬': `<svg class="note-emoji-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`,
    };
    const emojiSvg = EMOJI_MAP[msg.emoji || '📝'] || EMOJI_MAP['📝'];
    const cleanName = escapeHTML(msg.nickname);
    const cleanContent = escapeHTML(msg.content);

    return `
      <div class="note-card ${colorClass}" id="card-${msg.id}">
        <div class="note-emoji-stamp">${emojiSvg}</div>
        <p class="note-text">"${cleanContent}"</p>
        <div class="note-meta">
          <span class="note-author">@ ${cleanName}</span>
          <span class="note-date">${msg.date}</span>
        </div>
      </div>
    `;
  }

  function createFriendCardHTML(friend: Friend): string {
    return `
      <a href="${friend.url}" target="_blank" rel="noopener noreferrer" class="friend-card" style="--aura-color: ${friend.themeColor}">
        <div class="friend-aura"></div>
        <div class="friend-card-inner">
          <div class="friend-avatar-container">
            <img src="${friend.avatar}" alt="${friend.name} 头像" class="friend-avatar" loading="lazy" onerror="this.src='/images/touxiang.png'" />
          </div>
          <div class="friend-info">
            <h3 class="friend-name">
              <span>${friend.name}</span>
              <svg class="friend-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </h3>
            <p class="friend-desc" title="${friend.description}">${friend.description}</p>
          </div>
        </div>
      </a>
    `;
  }

  function initInteraction() {
    // --- 1. Tab Switching ---
    const tabBtns = document.querySelectorAll('.tab-btn');
    const slider = document.getElementById('tab-slider');
    
    function switchTab(tabId: string, animate: boolean = true) {
      const activeBtn = document.querySelector(`.tab-btn[data-tab="${tabId}"]`) as HTMLElement | null;
      if (!activeBtn) return;

      // Update button classes
      tabBtns.forEach(btn => btn.classList.toggle('active', btn === activeBtn));

      // Update slider styles
      if (slider) {
        if (!animate) {
          slider.style.transition = 'none';
        } else {
          slider.style.transition = 'left 0.3s cubic-bezier(0.25, 1, 0.5, 1), width 0.3s cubic-bezier(0.25, 1, 0.5, 1)';
        }
        slider.style.left = `${activeBtn.offsetLeft}px`;
        slider.style.width = `${activeBtn.offsetWidth}px`;
        if (!animate) {
          // Force layout reflow then restore transition
          slider.offsetHeight;
          slider.style.transition = '';
        }
      }

      // Switch panels
      const contents = ['guestbook', 'friends'];
      contents.forEach(c => {
        const el = document.getElementById(`tab-content-${c}`);
        if (!el) return;
        if (c === tabId) {
          el.style.display = 'block';
          if (animate) {
            // Trigger animation
            el.offsetHeight;
            el.classList.add('active');
          } else {
            el.classList.add('active');
          }
        } else {
          el.classList.remove('active');
          if (animate) {
            setTimeout(() => {
              if (!el.classList.contains('active')) {
                el.style.display = 'none';
              }
            }, 300);
          } else {
            el.style.display = 'none';
          }
        }
      });
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        if (tab) switchTab(tab);
      });
    });

    // Run initial tab setup (no animation) - 友链优先
    switchTab('friends', false);

    // Re-verify slider width on window resize
    window.addEventListener('resize', () => {
      const activeBtn = document.querySelector('.tab-btn.active') as HTMLElement | null;
      if (activeBtn && slider) {
        slider.style.transition = 'none';
        slider.style.left = `${activeBtn.offsetLeft}px`;
        slider.style.width = `${activeBtn.offsetWidth}px`;
      }
    }, { passive: true });


    // --- 2. Guestbook Logic ---
    const board = document.getElementById('guestbook-board');
    const form = document.getElementById('guestbook-form') as HTMLFormElement | null;
    
    if (board && form) {
      let messages: Message[] = [];
      let isKVEnabled = false;

      // Render local messages immediately as placeholder/skeleton
      const localMessages = getSavedMessages();
      board.innerHTML = localMessages.map(msg => createCardHTML(msg)).join('');

      // Attempt to load from Cloudflare KV backend API
      const loadKVMessages = async () => {
        try {
          const res = await fetch('/api/messages');
          if (res.ok) {
            messages = await res.json();
            isKVEnabled = true;
            board.innerHTML = messages.map(msg => createCardHTML(msg)).join('');
            console.log('[Guestbook] Loaded messages successfully from Cloudflare KV.');
          } else {
            console.warn('[Guestbook] KV API returned error status, falling back to LocalStorage.');
            messages = localMessages;
          }
        } catch (err) {
          console.warn('[Guestbook] Failed to connect to KV API (local dev or offline), falling back to LocalStorage.', err);
          messages = localMessages;
        }
      };

      loadKVMessages();

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const nicknameInput = document.getElementById('gb-nickname') as HTMLInputElement;
        const contentInput = document.getElementById('gb-content') as HTMLInputElement;
        const emojiRadio = form.querySelector('input[name="gb-emoji"]:checked') as HTMLInputElement | null;
        const colorRadio = form.querySelector('input[name="gb-color"]:checked') as HTMLInputElement | null;

        const nickname = nicknameInput.value.trim();
        const content = contentInput.value.trim();
        const emoji = emojiRadio ? emojiRadio.value : '📝';
        const colorIndex = colorRadio ? parseInt(colorRadio.value, 10) : 1;

        if (!nickname || !content) return;

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (submitBtn) submitBtn.disabled = true;

        const now = new Date();
        const dateStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
        
        const payload = { nickname, content, emoji, colorIndex };
        let newMsg: Message | null = null;

        if (isKVEnabled) {
          try {
            const res = await fetch('/api/messages', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });
            if (res.ok) {
              newMsg = await res.json();
            } else {
              console.error('[Guestbook] KV POST failed, falling back to LocalStorage.');
            }
          } catch (err) {
            console.error('[Guestbook] KV POST failed with exception, falling back to LocalStorage.', err);
          }
        }

        // Fallback to LocalStorage if KV was disabled or post failed
        if (!newMsg) {
          newMsg = {
            id: Date.now().toString(),
            nickname,
            content,
            date: dateStr,
            colorIndex,
            emoji
          };
          messages.unshift(newMsg);
          saveMessages(messages);
        }

        // Render card with entry transition
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = createCardHTML(newMsg);
        const cardEl = tempDiv.firstElementChild as HTMLElement;
        cardEl.classList.add('is-new');
        
        board.insertBefore(cardEl, board.firstChild);
        
        // Trigger reflow
        cardEl.offsetHeight;
        cardEl.classList.remove('is-new');

        form.reset();
        if (submitBtn) submitBtn.disabled = false;

        // Trigger confetti particle effect
        if (submitBtn && window.triggerConfetti) {
          const rect = submitBtn.getBoundingClientRect();
          window.triggerConfetti(rect.left + rect.width / 2, rect.top + rect.height / 2);
        }
      });
    }

    // --- 3. Friends Link Render ---
    const friendsGrid = document.getElementById('friends-grid');
    if (friendsGrid) {
      friendsGrid.innerHTML = FRIENDS.map(f => createFriendCardHTML(f)).join('');
    }

    // --- 4. Info Copy Logic ---
    const copyBtn = document.getElementById('copy-info-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const codeEl = document.getElementById('friend-json-code');
        const btnText = copyBtn.querySelector('.copy-btn-text');
        if (codeEl && btnText) {
          navigator.clipboard.writeText(codeEl.textContent || '')
            .then(() => {
              btnText.textContent = '已复制!';
              copyBtn.classList.add('copied');
              setTimeout(() => {
                btnText.textContent = '复制格式';
                copyBtn.classList.remove('copied');
              }, 2000);
            })
            .catch(err => {
              console.error('Failed to copy text: ', err);
            });
        }
      });
    }
  }

  if (!(window as any).__guestbookInitialized) {
    (window as any).__guestbookInitialized = true;
    document.addEventListener('astro:page-load', initInteraction);
  }
</script>

