                    </svg>
                  </span>
                  <h4>软件利器</h4>
                </div>
                <div class="toolbox-tags-row">
                  <span class="badge">Codex</span>
                  <span class="badge">Antigravity</span>
                  <span class="badge">Trae</span>
                  <span class="badge">Obsidian</span>
                  <span class="badge">GitHub</span>
                  <span class="badge">Cloudflare</span>
                  <span class="badge">Keystatic</span>
