                      <span class="contact-label">星铁 UID (港澳台)</span>
                      <span class="contact-value">901549277</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </ScrollReveal>

          <!-- 软件利器 -->
          <ScrollReveal animation="fade-up" delay={150}>
            <div class="glass-card about-toolbox-card">
              <div class="about-section-block">
                <div class="toolbox-header-row">
                  <span class="toolbox-icon">
                    <svg class="toolbox-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
