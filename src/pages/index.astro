                      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                      <line x1="8" y1="21" x2="16" y2="21"></line>
                      <line x1="12" y1="17" x2="12" y2="21"></line>
                    </svg>
                  </span>
                  <h4>开发栈</h4>
                </div>
                <div class="lang-list">
                  <!-- Python 15% -->
                  <div class="lang-row lang-level-15" title="Python: 15% 掌握度">
                    <div class="lang-row-left">
