<script>
  function updateGreeting() {
    const greetingEl = document.getElementById('dynamic-greeting');
    if (!greetingEl) return;
    
    const hour = new Date().getHours();
    let text = '你好，';
    if (hour >= 0 && hour < 6) {
      text = '凌晨好！';
    } else if (hour >= 6 && hour < 11) {
      text = '早上好！';
    } else if (hour >= 11 && hour < 13) {
      text = '中午好！';
    } else if (hour >= 13 && hour < 18) {
      text = '下午好！';
    } else if (hour >= 18 && hour < 23) {
      text = '晚上好！';
    } else {
      text = '深夜好！';
    }
    
    greetingEl.textContent = text;
  }

  function initTypewriter() {
    const el = document.getElementById('typed-bio');
    if (!el) return;
    const typedEl = el;
    
    // Clean up existing cursor if any
    const existingCursor = typedEl.nextSibling as HTMLElement | null;
    if (existingCursor && existingCursor.classList && existingCursor.classList.contains('typing-cursor')) {
      existingCursor.remove();
    }
    
    if (!typedEl.dataset.originalText) {
      typedEl.dataset.originalText = typedEl.textContent ? typedEl.textContent.trim() : '';
    }
    
    const text = typedEl.dataset.originalText;
    typedEl.textContent = '';
    
    let index = 0;
    const speed = 40; // ms per char
    
    // Create cursor
    const cursor = document.createElement('span');
    cursor.className = 'typing-cursor';
    cursor.textContent = '|';
    typedEl.parentNode?.insertBefore(cursor, typedEl.nextSibling);
    
    let timerId: any;
    function type() {
      if (index < text.length) {
        typedEl.textContent += text.charAt(index);
        index++;
        timerId = setTimeout(type, speed);
      } else {
        cursor.classList.add('finished');
      }
    }
    
    type();
    
    // Clean up on page swap
    document.addEventListener('astro:before-swap', () => {
      clearTimeout(timerId);
      cursor.remove();
    }, { once: true });
  }

  // 每次页面加载（包括单页跳转）时运行
  document.addEventListener('astro:page-load', () => {
    updateGreeting();
    initTypewriter();
  });
</script>

