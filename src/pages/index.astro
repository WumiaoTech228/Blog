                      </svg>
                    </span>
                    <div class="contact-info">
                      <span class="contact-label">QQ</span>
                      <span class="contact-value">1419956461</span>
                    </div>
                  </div>

                  <!-- B站 -->
                  <a href="https://space.bilibili.com/3494377160706567" target="_blank" rel="noopener noreferrer" class="contact-item linkable" title="访问我的 B站 个人空间">
                    <span class="contact-icon-wrapper bili-brand">
