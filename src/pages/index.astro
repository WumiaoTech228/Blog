---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';
import { getPostReadingTime, getPostSlug, getPublishedPosts } from '../utils/posts';
import type { BlogPost } from '../utils/posts';

// 获取博客文章列表，按日期倒序排列，排除草稿
let posts: BlogPost[] = [];
try {
  const allPosts = await getCollection('blog');
  posts = getPublishedPosts(allPosts);
} catch (e) {
  posts = [];
}
---

<Layout title="无渺の个人小站" description={SITE.description}>
  <div class="index-layout container">
    <!-- 首屏 Hero Area -->
    <section class="hero-fold">
      <div class="hero-grid">
        <!-- 左侧：个人详细介绍 -->
        <div class="hero-intro-area">
          <ScrollReveal animation="fade-up" delay={0}>
            <div class="greeting-container">
              <span class="active-status-dot" title="博主目前在线折腾中" aria-hidden="true"></span>
              <span id="dynamic-greeting" class="dynamic-greeting-text">你好，</span>
            </div>
          </ScrollReveal>
          <ScrollReveal animation="fade-up" delay={80}>
            <h1 class="intro-title"><span class="highlight">这里是无渺の小站，祝你今天开心 (つ´ω`)つ</span></h1>
          </ScrollReveal>
          <ScrollReveal animation="fade-up" delay={160}>
            <p class="intro-tagline">学生开发者 / Vibe Coder</p>
          </ScrollReveal>
          <ScrollReveal animation="fade-up" delay={240}>
            <p class="intro-bio" id="typed-bio">
              记录日常代码、折腾笔记与生活观察。相信直觉，享受纯粹的写码快乐。正在做的开源项目有本站和 LepoProxy。
            </p>
          </ScrollReveal>
          <ScrollReveal animation="fade-up" delay={320}>
            <div class="tech-stack-row">
              <span class="tech-pill">Astro</span>
              <span class="tech-pill">TypeScript</span>
              <span class="tech-pill">Go</span>
              <span class="tech-pill">React</span>
              <span class="tech-pill">Cloudflare</span>
            </div>
          </ScrollReveal>
          <ScrollReveal animation="fade-up" delay={400}>
            <div class="intro-links">
              <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="btn-primary" title="GitHub">
                <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="link-icon"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                GitHub
              </a>
              <a href={`mailto:${SITE.email}`} class="btn-outline" title="Email">
                <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="link-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                Email 联系我
              </a>
            </div>
          </ScrollReveal>
        </div>

        <!-- 右侧：精选项目展示 -->
        <ScrollReveal animation="fade-up" delay={200}>
          <div class="hero-projects-area">
            <div class="glass-card projects-card">
              <div class="projects-aura"></div>
              <div class="projects-card-inner">
                <h3 class="projects-card-title">最近在做</h3>
                <div class="projects-list-vertical">
                  <div class="project-card-item">
                    <div class="proj-header">
                      <h4 class="proj-title">
                        <a href="/projects/">Blog</a>
                      </h4>
                      <span class="proj-status active">已上线</span>
                    </div>
                    <p class="proj-desc">基于 Astro & Keystatic 构建的无服务器个人博客，本站的底层驱动。</p>
                    <div class="proj-meta-tags">
                      <span class="badge">Astro</span>
                      <span class="badge">Keystatic</span>
                    </div>
                  </div>

                  <div class="project-card-item">
                    <div class="proj-header">
                      <h4 class="proj-title">
                        <a href="/projects/">LepoProxy</a>
                      </h4>
                      <span class="proj-status coding">开发中</span>
                    </div>
                    <p class="proj-desc">基于 Tauri v2 + Sing-Box 内核构筑的下一代全协议桌面代理客户端。</p>
                    <div class="proj-meta-tags">
                      <span class="badge">Tauri v2</span>
                      <span class="badge">Rust</span>
                      <span class="badge">Sing-Box</span>
                    </div>
                  </div>

                  <div class="project-card-item">
                    <div class="proj-header">
                      <h4 class="proj-title">
                        <a href="/projects/">GlimOfficeInstaller</a>
                      </h4>
                      <span class="proj-status coding">开发中</span>
                    </div>
                    <p class="proj-desc">便携、轻量化、原版化的微软 Office 安装与激活部署工具。</p>
                    <div class="proj-meta-tags">
                      <span class="badge">C#</span>
                      <span class="badge">.NET</span>
                      <span class="badge">Ohook</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </ScrollReveal>
      </div>

      <!-- 向下滑动指示 -->
      <div class="scroll-indicator">
        <a href="#blog-section" class="scroll-link" aria-label="向下滑动查看文章">
          <span class="scroll-text">最新文章</span>
          <svg class="scroll-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <polyline points="19 12 12 19 5 12"></polyline>
          </svg>
        </a>
      </div>
    </section>

    <!-- 新增：关于 & 装备库版块 -->
    <section id="about-section" class="about-fold">
      <div class="section-header">
        <h2 class="section-title">关于我 & 装备库</h2>
      </div>

      <div class="about-hero-grid">
        <!-- 左侧列：关于我与本站介绍 + 软件利器 -->
        <div class="about-bio-panel">
          <ScrollReveal animation="fade-up" delay={0}>
            <div class="glass-card about-left-card">
              <div class="about-section-block">
                <h3 class="card-subtitle-small">关于我</h3>
                <p class="bio-text">
                  你好，我是 <strong>无渺</strong>，一名学生开发者。这里记录我的开发过程、工具折腾和一些持续更新的想法。我喜欢折腾各种有趣的技术，也会把踩坑过程 and 复盘记录下来。本站更像一份长期维护的开发日志，相信直觉，享受纯粹的写码快乐。
                </p>
              </div>
              
              <div class="about-section-divider"></div>
              
              <div class="about-section-block">
                <h3 class="card-subtitle-small">关于本站</h3>
                <p class="bio-text">
                  本站是一个 100% 静态生成的无服务器网站。采用 <strong>Astro</strong> 编译静态页面，速度极快；使用 <strong>Keystatic</strong> 充当 Git-backed CMS 文本管理面板；全量部署于 <strong>Cloudflare Pages</strong> 全球边缘网络，享受零服务器开销与高安全性。
                </p>
              </div>

              <div class="about-section-divider"></div>

              <div class="about-section-block">
                <h3 class="card-subtitle-small">联络与联机</h3>
                <div class="contact-grid">
                  <!-- QQ -->
                  <div class="contact-item" title="QQ: 1419956461">
