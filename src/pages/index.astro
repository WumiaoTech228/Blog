              </div>
            </div>
          </ScrollReveal>
        </div>

        <!-- 右侧列：开发栈 + 桌面环境 -->
        <div class="about-toolbox-panel">
          <!-- 开发栈 -->
          <ScrollReveal animation="fade-up" delay={100}>
            <div class="glass-card about-right-card">
              <div class="about-section-block">
                <div class="toolbox-header-row">
                  <span class="toolbox-icon">
