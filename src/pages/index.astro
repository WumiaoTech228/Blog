                    <span class="contact-icon-wrapper sr-brand">
                      <svg class="contact-svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
