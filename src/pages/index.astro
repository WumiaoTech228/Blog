                    </div>
                    <div class="lang-row-right">
                      <span class="lang-percent-badge">5%</span>
                    </div>
                  </div>

                  <!-- C# 1% -->
                  <div class="lang-row lang-level-1" title="C#: 1% 掌握度">
                    <div class="lang-row-left">
                      <svg class="lang-svg-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
