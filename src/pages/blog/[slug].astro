---
import Layout from '../../layouts/Layout.astro';
import TOC from '../../components/TOC.astro';
import { getCollection, render } from 'astro:content';
import { SITE } from '../../config';
import { slugifyTag } from '../../utils/tag';
import { getPostReadingTime, getPostSlug, getPublishedPosts } from '../../utils/posts';

// 1. 定义动态路由：为每一篇博客文章生成静态页面路径
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const activeEntries = getPublishedPosts(blogEntries);

  return activeEntries.map((entry, index) => {
    const slug = getPostSlug(entry);
    const newer = index > 0 ? activeEntries[index - 1] : null;
    const older = index < activeEntries.length - 1 ? activeEntries[index + 1] : null;
    const currentTagSlugs = new Set((entry.data.tags || []).map(tag => slugifyTag(tag)).filter(Boolean));
    const related = activeEntries
      .filter(other => other.id !== entry.id)
      .map(other => {
        const sharedTags = (other.data.tags || []).filter(tag => currentTagSlugs.has(slugifyTag(tag)));
        return {
          entry: other,
          score: sharedTags.length,
        };
      })
      .filter(item => item.score > 0)
      .sort((a, b) => b.score - a.score || b.entry.data.date.getTime() - a.entry.data.date.getTime())
      .slice(0, 3)
      .map(item => ({
        title: item.entry.data.title,
        description: item.entry.data.description,
        date: item.entry.data.date,
        slug: getPostSlug(item.entry),
        readingTime: getPostReadingTime(item.entry),
        tags: item.entry.data.tags,
      }));

    return {
      params: { slug },
      props: {
        entry,
        older: older ? { title: older.data.title, slug: getPostSlug(older) } : null,
        newer: newer ? { title: newer.data.title, slug: getPostSlug(newer) } : null,
        related,
      },
    };
  });
}

const { entry, older, newer, related } = Astro.props;
// 渲染 Markdown 内容并提取标题列表 (headings)
const { Content, headings } = await render(entry);

// 格式化日期的辅助函数
const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const readingTime = getPostReadingTime(entry);

// 构造 GEO / AI 搜索引擎专用的 JSON-LD 结构化数据
const postUrl = new URL(Astro.url.pathname, Astro.site || SITE.url).toString();
const jsonLdSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": entry.data.date.toISOString(),
  "dateModified": (entry.data.updatedDate || entry.data.date).toISOString(),
  "keywords": entry.data.tags?.join(', '),
  "image": entry.data.coverImage ? new URL(entry.data.coverImage.src, Astro.url).toString() : undefined,
  "author": {
    "@type": "Person",
    "name": SITE.author
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  }
});
---

<Layout 
  title={`${entry.data.title} - ${SITE.title}`} 
  description={entry.data.description}
  articleDate={entry.data.date.toISOString()}
  image={entry.data.coverImage?.src}
  schema={jsonLdSchema}
  tags={entry.data.tags}
>
  <!-- 1. 只在文章设置了封面图时展示顶部 Banner -->
  {entry.data.coverImage && (
    <div class="post-banner-wrapper">
      <img 
        src={entry.data.coverImage.src} 
        alt={entry.data.title} 
        class="post-banner-img" loading="eager" fetchpriority="high"
      />
    </div>
  )}

  <div class={`post-layout-container container ${entry.data.coverImage ? 'has-banner' : 'no-banner'}`}>
    <!-- 2. 三栏式布局结构 -->
    <div class="post-three-columns">
      
      <!-- 2.2 中栏：文章核心正文 -->
      <main class="post-main-content">
        <article class="glass-card post-article-card">
          <nav class="breadcrumb" aria-label="面包屑导航">
            <a href="/">首页</a>
            <span>/</span>
            <a href="/archive/">文章</a>
          </nav>

          <header class="article-header">
            <div class="article-meta">
              <time datetime={entry.data.date.toISOString()}>
                {formatDate(entry.data.date)}
              </time>
              <span class="meta-separator">&middot;</span>
              <span>{readingTime} 分钟阅读</span>
              {entry.data.updatedDate && (
                <>
                  <span class="meta-separator">&middot;</span>
                  <span class="updated-date">更新于 {formatDate(entry.data.updatedDate)}</span>
                </>
              )}
            </div>
            <h1 class="article-title">{entry.data.title}</h1>
            {entry.data.tags && entry.data.tags.length > 0 && (
              <div class="article-tags">
                {entry.data.tags.map((tag: string) => (
                  <a href={`/tags/${slugifyTag(tag)}/`} class="article-tag">#{tag}</a>
                ))}
              </div>
            )}
            {entry.data.description && (
              <p class="article-summary">{entry.data.description}</p>
            )}
          </header>
          
          {headings.length > 0 && (
            <div class="mobile-toc-container">
              <details class="mobile-toc-details">
                <summary class="mobile-toc-summary">
                  <span class="toc-summary-icon">
                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="8" y1="6" x2="21" y2="6"></line>
                      <line x1="8" y1="12" x2="21" y2="12"></line>
                      <line x1="8" y1="18" x2="21" y2="18"></line>
                      <line x1="3" y1="6" x2="3.01" y2="6"></line>
                      <line x1="3" y1="12" x2="3.01" y2="12"></line>
                      <line x1="3" y1="18" x2="3.01" y2="18"></line>
                    </svg>
                  </span>
                  文章目录 (TOC)
                </summary>
                <div class="mobile-toc-content">
                  <TOC headings={headings} />
                </div>
              </details>
            </div>
          )}
          
          <div class="prose">
            <Content />
          </div>

          <!-- 文章分享按钮组 -->
          <div class="share-bar">
            <span class="share-bar-label">分享文章</span>
            <button class="share-btn" id="share-twitter" aria-label="分享到 Twitter">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16h-4.267z"></path><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path></svg>
              Twitter / X
            </button>
            <button class="share-btn" id="share-copy-link" aria-label="复制链接">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
              复制链接
            </button>
          </div>

          <footer class="article-footer">
            {related.length > 0 && (
              <section class="related-posts" aria-labelledby="related-title">
                <h2 id="related-title" class="footer-section-title">相关文章</h2>
                <div class="related-list">
                  {related.map(post => (
                    <a href={`/blog/${post.slug}/`} class="related-item">
                      <span class="related-title">{post.title}</span>
                      <span class="related-meta">{formatDate(post.date)} · {post.readingTime} 分钟阅读</span>
                      <span class="related-desc">{post.description}</span>
                    </a>
                  ))}
                </div>
              </section>
            )}

            {(older || newer) && (
              <div class="prev-next-nav" aria-label="文章导航">
                {older ? (
                  <a href={`/blog/${older.slug}/`} class="nav-link prev">
                    <span class="nav-label">&larr; 上一篇</span>
                    <span class="nav-title">{older.title}</span>
                  </a>
                ) : (
                  <div class="nav-placeholder"></div>
                )}
                {newer ? (
                  <a href={`/blog/${newer.slug}/`} class="nav-link next">
                    <span class="nav-label">下一篇 &rarr;</span>
                    <span class="nav-title">{newer.title}</span>
                  </a>
                ) : (
                  <div class="nav-placeholder"></div>
                )}
              </div>
            )}
          </footer>
        </article>
      </main>

      <!-- 2.3 右栏：文章目录 (TOC) -->
      <aside class="sidebar-right">
        <div class="toc-wrapper">
          <TOC headings={headings} />
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style>
  /* 1. Banner 横幅样式 */
  .post-banner-wrapper {
    width: 100%;
    height: 25vh;
    min-height: 200px;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
  }
  .post-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 2. 容器与偏移逻辑 */
  .post-layout-container {
    position: relative;
    z-index: 10;
  }
  .post-layout-container.has-banner {
    margin-top: -40px; /* 半贴在横幅上 */
  }
  .post-layout-container.no-banner {
    margin-top: 5.5rem;
  }

  .post-three-columns {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 2.5rem;
    align-items: start;
  }

  /* 目录定位 */
  .sidebar-right {
    position: sticky;
    top: 90px;
  }
  .toc-wrapper {
    background: transparent;
    border: none;
    border-left: 1px solid var(--border-color);
    border-radius: 0;
    padding: 0.25rem 0 0.25rem 1rem;
    box-shadow: none;
  }

  /* 中栏：文章详情 */
  .post-main-content {
    min-width: 0;
  }
  .post-article-card {
    padding: 3rem 2.5rem;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .breadcrumb a {
    color: var(--text-muted);
  }
  .breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px dashed var(--border-color);
    padding-bottom: 1.5rem;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }
  .meta-separator {
    opacity: 0.35;
  }
  .article-title {
    font-size: clamp(1.8rem, 3.5vw, 2.3rem);
    line-height: 1.3;
    font-weight: 500;
    color: var(--text-main);
  }
  .article-summary {
    font-size: 1rem;
    color: var(--text-muted);
    border-left: 3px solid var(--color-accent);
    padding-left: 0.8rem;
    line-height: 1.6;
    margin-top: 1rem;
  }
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.8rem;
    margin-bottom: 0.5rem;
  }
  .article-tag {
    font-size: 0.8rem;
    color: var(--color-accent);
    background: var(--color-accent-bg);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
  }
  .article-tag:hover {
    background: var(--color-accent);
    color: var(--bg-color) !important;
    border-color: var(--color-accent);
  }
  .article-footer {
    margin-top: 3.5rem;
    border-top: 1px dashed var(--border-color);
    padding-top: 2rem;
  }
  .related-posts {
    margin-bottom: 2rem;
  }
  .footer-section-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 1rem;
  }
  .related-list {
    display: grid;
    gap: 0.75rem;
  }
  .related-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--card-bg);
  }
  .related-item:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-bg);
  }
  .related-title {
    color: var(--text-main);
    font-weight: 600;
  }
  .related-meta,
  .related-desc {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .related-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .prev-next-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .nav-link {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--card-bg);
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .nav-link:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-bg);
    transform: translateY(-2px);
  }
  .nav-link.next {
    text-align: right;
    align-items: flex-end;
  }
  .nav-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .nav-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }
  .nav-placeholder {
    flex: 1;
  }
  @media (max-width: 576px) {
    .prev-next-nav {
      flex-direction: column;
    }
  }

  /* 响应式断点 */
  @media (max-width: 1024px) {
    .post-three-columns {
      grid-template-columns: 1fr; /* 隐藏右侧 TOC */
    }
    .sidebar-right {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .post-three-columns {
      grid-template-columns: 1fr;
    }
    .post-article-card {
      padding: 2rem 1.25rem;
      border-radius: var(--radius-sm);
    }
  }
</style><script>
  let isScrollingRegistered = false;

  // Reading progress bar scroll handler (registered once globally)
  function updateProgressBar() {
    const bar = document.getElementById("reading-progress");
    if (!bar) return;
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    bar.style.width = (docHeight > 0 ? (scrollTop / docHeight) * 100 : 0) + "%";
  }

  // ==========================================
  // 图片灯箱预览 (using event delegation on .prose)
  // ==========================================
  function initLightbox() {
    let overlay = document.querySelector('.lightbox-overlay') as HTMLElement | null;

    if (!overlay) {
      overlay = document.createElement('div');
      overlay.className = 'lightbox-overlay';
      overlay.setAttribute('role', 'dialog');
      overlay.setAttribute('aria-modal', 'true');
      overlay.setAttribute('aria-label', '图片预览');
      overlay.innerHTML = '<img src="" alt="" />';
      document.body.appendChild(overlay);
      
      const handleClose = () => {
        overlay!.classList.remove('is-active');
      };
      overlay.addEventListener('click', handleClose);

      const handleEscape = (e: KeyboardEvent) => {
        if (e.key === 'Escape' && overlay!.classList.contains('is-active')) {
          handleClose();
        }
      };
      document.addEventListener('keydown', handleEscape);

      const cleanupLightbox = () => {
        overlay?.removeEventListener('click', handleClose);
        document.removeEventListener('keydown', handleEscape);
        overlay?.remove();
      };
      document.addEventListener('astro:before-swap', cleanupLightbox, { once: true });
    }
    const overlayImg = overlay.querySelector('img')!;

    // Event delegation on the .prose element to prevent duplicate listener accumulation
    const prose = document.querySelector('.prose');
    if (prose && !prose.classList.contains('lightbox-registered')) {
      prose.classList.add('lightbox-registered');

      prose.querySelectorAll('img').forEach((img) => {
        (img as HTMLElement).style.cursor = 'zoom-in';
      });

      prose.addEventListener('click', (e) => {
        const img = (e.target as HTMLElement).closest('img');
        if (!img) return;
        e.stopPropagation();
        overlayImg.src = img.src;
        overlayImg.alt = img.alt;
        overlay!.classList.add('is-active');
      });
    }
  }

  // ==========================================
  // 代码块语言标签
  // ==========================================
  function initCodeLangLabels() {
    document.querySelectorAll('.prose pre code').forEach((code) => {
      const pre = code.parentElement;
      if (!pre || pre.querySelector('.code-lang-label')) return;
      // Extract language from class (e.g. 'language-js' -> 'js')
      const langClass = Array.from(code.classList).find(c => c.startsWith('language-'));
      if (!langClass) return;
      const lang = langClass.replace('language-', '');
      if (!lang || lang === 'plaintext') return;
      const label = document.createElement('span');
      label.className = 'code-lang-label';
      label.textContent = lang;
      pre.appendChild(label);
    });
  }

  // ==========================================
  // 文章分享按钮
  // ==========================================
  function initShareButtons() {
    var twitterBtn = document.getElementById('share-twitter');
    var copyBtn = document.getElementById('share-copy-link');

    if (twitterBtn && !twitterBtn.dataset.listenerRegistered) {
      twitterBtn.dataset.listenerRegistered = 'true';
      twitterBtn.addEventListener('click', function() {
        var url = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(document.title) + '&url=' + encodeURIComponent(window.location.href);
        window.open(url, '_blank', 'width=550,height=420');
      });
    }

    if (copyBtn && !copyBtn.dataset.listenerRegistered) {
      copyBtn.dataset.listenerRegistered = 'true';
      copyBtn.addEventListener('click', function() {
        var url = window.location.href;
        function copyDone() {
          copyBtn!.classList.add('copied');
          copyBtn!.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 已复制';
          setTimeout(function() {
            copyBtn!.classList.remove('copied');
            copyBtn!.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg> 复制链接';
          }, 2000);
        }
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(url).then(copyDone).catch(function() {
            // Fallback if clipboard permission denied
            var textarea = document.createElement('textarea');
            textarea.value = url;
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
            copyDone();
          });
        } else {
          // HTTP fallback
          var textarea = document.createElement('textarea');
          textarea.value = url;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
          copyDone();
        }
      });
    }
  }

  function initBlogPage() {
    // 仅在博客文章详情页（以 /blog/ 开头）初始化进度条与复制按钮，非文章页则移除进度条
    if (!window.location.pathname.startsWith('/blog/')) {
      const bar = document.getElementById("reading-progress");
      if (bar) bar.remove();
      if (isScrollingRegistered) {
        window.removeEventListener("scroll", updateProgressBar);
        isScrollingRegistered = false;
      }
      return;
    }

    // 1. Copy button for code blocks
    document.querySelectorAll(".prose pre").forEach(function (pre) {
      if (pre.querySelector(".code-copy-btn")) return; // Prevent duplicates

      var btn = document.createElement("button");
      btn.className = "code-copy-btn";
      btn.textContent = "复制";
      btn.setAttribute("aria-label", "复制代码");
      btn.addEventListener("click", function () {
        var code = pre.querySelector("code");
        if (!code) return;
        var text = code.textContent || "";
        // 使用 Clipboard API，在不安全的 HTTP 上下文时降级到 execCommand
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(text).then(function () {
            btn.textContent = "已复制";
            setTimeout(function () { btn.textContent = "复制"; }, 2000);
          }, function () { btn.textContent = "失败"; });
        } else {
          // HTTP fallback
          var textarea = document.createElement("textarea");
          textarea.value = text;
          textarea.style.position = "fixed";
          textarea.style.opacity = "0";
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand("copy");
          document.body.removeChild(textarea);
          btn.textContent = "已复制";
          setTimeout(function () { btn.textContent = "复制"; }, 2000);
        }
      });
      pre.appendChild(btn);
    });

    // 2. Reading progress bar initialization
    var bar = document.getElementById("reading-progress");
    if (!bar) {
      bar = document.createElement("div");
      bar.id = "reading-progress";
      bar.className = "reading-progress";
      document.body.prepend(bar);
    }
    updateProgressBar();

    if (!isScrollingRegistered) {
      window.addEventListener("scroll", updateProgressBar, { passive: true });
      isScrollingRegistered = true;
    }

    // 3. Image lightbox
    initLightbox();

    // 4. Code language labels
    initCodeLangLabels();

    // 5. Share buttons
    initShareButtons();
  }

  // Ensure scripts are initialized only once globally via a window-level flag
  if (!(window as any).__blogScriptsInitialized) {
    (window as any).__blogScriptsInitialized = true;

    // Listen to astro:page-load to support both initial load and client transitions
    document.addEventListener("astro:page-load", initBlogPage);

    document.addEventListener("astro:before-swap", () => {
      if (isScrollingRegistered) {
        window.removeEventListener("scroll", updateProgressBar);
        isScrollingRegistered = false;
      }
    });
  }
</script>

<style>
